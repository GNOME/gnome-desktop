#~ msgid "CRTC %d cannot drive output %s"
#~ msgstr "le CRTC %d ne peut pas piloter une sortie %s"

#, c-format
#~ msgid "output %s does not support mode %dx%d@%dHz"
#~ msgstr "la sortie %s ne prend pas en charge le mode %dx%d@%dHz"

