#: libgnome-desktop/gnome-languages.c:1375
msgid "IQTElif"
msgstr "IQTElif"

#. TRANSLATORS: The alphabet/script, not the language. Used to distinguish
#. Latin from Cyrillic written language variants.
#: libgnome-desktop/gnome-languages.c:1378
msgid "Latin"
msgstr "alfabet ЕӮaciЕ„ski"

#. TRANSLATORS: "Saho" is a variant of the Afar language. Used to
#. distinguish the label representing the aa_ER locale from aa_ER@saaho.
#: libgnome-desktop/gnome-languages.c:1381
msgid "Saho"
msgstr "saho"

#. TRANSLATORS: "Valencia" is a dialect of the Catalan language spoken
#. in Valencia. Used to distinguish the label representing the ca_ES
#. locale from ca_ES@valencia.
#: libgnome-desktop/gnome-languages.c:1385
msgid "Valencia"
msgstr "walencki"

#. Translators: This is the time format with full date
#. plus day used in 24-hour mode. Please keep the under-
#. score to separate the date from the time.
#: libgnome-desktop/gnome-wall-clock.c:337
msgid "%a %b %-e_%R:%S"
msgstr "%a %-d %b_%HвҲ¶%MвҲ¶%S"

#: libgnome-desktop/gnome-wall-clock.c:338
msgid "%a %b %-e_%R"
msgstr "%a %-d %b_%HвҲ¶%M"

#. Translators: This is the time format with full date
#. used in 24-hour mode. Please keep the underscore to
#. separate the date from the time.
#: libgnome-desktop/gnome-wall-clock.c:343
msgid "%b %-e_%R:%S"
msgstr "%-d %b_%HвҲ¶%MвҲ¶%S"

#: libgnome-desktop/gnome-wall-clock.c:344
msgid "%b %-e_%R"
msgstr "%-d %b_%HвҲ¶%M"

#. Translators: This is the time format with day used
#. in 24-hour mode.
#: libgnome-desktop/gnome-wall-clock.c:348
msgid "%a %R:%S"
msgstr "%a %HвҲ¶%MвҲ¶%S"

#: libgnome-desktop/gnome-wall-clock.c:349
msgid "%a %R"
msgstr "%a %HвҲ¶%M"

#. Translators: This is the time format without date used
#. in 24-hour mode.
#: libgnome-desktop/gnome-wall-clock.c:353
msgid "%R:%S"
msgstr "%HвҲ¶%MвҲ¶%S"

#: libgnome-desktop/gnome-wall-clock.c:354
msgid "%R"
msgstr "%HвҲ¶%M"

#. Translators: This is a time format with full date
#. plus day used for AM/PM. Please keep the under-
#. score to separate the date from the time.
#: libgnome-desktop/gnome-wall-clock.c:362
msgid "%a %b %-e_%l:%M:%S %p"
msgstr "%a %-d %b_%-lвҲ¶%MвҲ¶%SвҖү%p"

#: libgnome-desktop/gnome-wall-clock.c:363
msgid "%a %b %-e_%l:%M %p"
msgstr "%a %-d %b_%-lвҲ¶%MвҖү%p"

#. Translators: This is a time format with full date
#. used for AM/PM. Please keep the underscore to
#. separate the date from the time.
#: libgnome-desktop/gnome-wall-clock.c:368
msgid "%b %-e_%l:%M:%S %p"
msgstr "%-d %b_%-lвҲ¶%MвҲ¶%SвҖү%p"

#: libgnome-desktop/gnome-wall-clock.c:369
msgid "%b %-e_%l:%M %p"
msgstr "%-d %b_%-lвҲ¶%MвҖү%p"

#. Translators: This is a time format with day used
#. for AM/PM.
#: libgnome-desktop/gnome-wall-clock.c:373
msgid "%a %l:%M:%S %p"
msgstr "%a %-lвҲ¶%MвҲ¶%SвҖү%p"

#: libgnome-desktop/gnome-wall-clock.c:374
msgid "%a %l:%M %p"
msgstr "%a %-lвҲ¶%MвҖү%p"

#. Translators: This is a time format without date used
#. for AM/PM.
#: libgnome-desktop/gnome-wall-clock.c:378
msgid "%l:%M:%S %p"
msgstr "%-lвҲ¶%MвҲ¶%SвҖү%p"

#: libgnome-desktop/gnome-wall-clock.c:379
msgid "%l:%M %p"
msgstr "%-lвҲ¶%MвҖү%p"

