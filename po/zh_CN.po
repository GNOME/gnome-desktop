#~ msgid ""
#~ "none of the selected modes were compatible with the possible modes:\n"
#~ "%s"
#~ msgstr ""
#~ "所选模式均不匹配可能的模式：\n"
#~ "%s"

#, c-format
#~ msgid ""
#~ "required virtual size does not fit available size: requested=(%d, %d), "
#~ "minimum=(%d, %d), maximum=(%d, %d)"
#~ msgstr ""
#~ "要求的虚拟尺寸不符合可用尺寸： 要求=(%d, %d)， 最小=(%d, %d)，最大=(%d, "
#~ "%d)"

