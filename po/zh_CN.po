#~ msgid "CRTC %d cannot drive output %s"
#~ msgstr "CRTC %d 不能驱动输出 %s"

#, c-format
#~ msgid "output %s does not support mode %dx%d@%dHz"
#~ msgstr "输出 %s 不支持 %dx%d@%dHz 模式"

#, c-format
#~ msgid "CRTC %d does not support rotation=%d"
#~ msgstr "CRTC %d 不支持旋转=%d"

